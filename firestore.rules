rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.email == 'teacher@ingyu-ai-world.com' ||
        (
          userDoc(request.auth.uid).data.role == 'teacher' &&
          userDoc(request.auth.uid).data.approved != false
        )
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMyStudent(data) {
      return isTeacher() && data.teacherId == request.auth.uid;
    }

    function isMyClass(data) {
      return isTeacher() && data.teacherId == request.auth.uid;
    }

    function isMyClassStudent(classId) {
      return isAuthenticated() &&
        userDoc(request.auth.uid).data.role == 'student' &&
        userDoc(request.auth.uid).data.classId == classId;
    }

    function doesNotChangeSensitiveUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'email',
        'teacherId',
        'classId',
        'classCodeUsed',
        'simplePassword',
        'pinHash',
        'pinSalt',
        'pinHashVersion',
        'uid'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isMyStudent(resource.data);
      allow create: if false;
      allow update: if isMyStudent(resource.data) || (isOwner(userId) && doesNotChangeSensitiveUserFields());
      allow delete: if false;
    }

    match /classes/{classId} {
      allow read: if isMyClass(resource.data) || isMyClassStudent(classId);
      allow create, update, delete: if false;
    }

    match /teacher_requests/{requestId} {
      allow read, write: if false;
    }

    match /class_app_approvals/{approvalId} {
      allow read: if isMyClass(resource.data) || isMyClassStudent(resource.data.classId);
      allow write: if false;
    }

    match /app_approvals/{appId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /usage_logs/{logId} {
      allow read: if isMyStudent(resource.data);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId
        && request.resource.data.keys().hasOnly([
          'userId',
          'userName',
          'teacherId',
          'classId',
          'appName',
          'appCategory',
          'clickedAt'
        ]);
      allow update: if false;
      allow delete: if isMyStudent(resource.data);
    }

    match /user_agreements/{userId} {
      allow read: if isOwner(userId) || isMyStudent(resource.data);
      allow write: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId;
    }

    match /emotional_checkins/{checkinId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId;
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isMyStudent(resource.data));
      allow update: if false;
      allow delete: if isMyStudent(resource.data);
    }
  }
}
