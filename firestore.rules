rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isTeacher() {
      return isAuthenticated() && (
        request.auth.token.email == 'teacher@ingyu-ai-world.com' ||
        (
          userDoc(request.auth.uid).data.role == 'teacher' &&
          userDoc(request.auth.uid).data.approved != false
        )
      );
    }

    function isAdmin() {
      return isTeacher() && (
        request.auth.token.email == 'teacher@ingyu-ai-world.com' ||
        userDoc(request.auth.uid).data.isAdmin == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMyStudent(data) {
      return isTeacher() && data.teacherId == request.auth.uid;
    }

    function isMyClass(data) {
      return isTeacher() && data.teacherId == request.auth.uid;
    }

    function isMyClassStudent(classId) {
      return isAuthenticated() &&
        userDoc(request.auth.uid).data.role == 'student' &&
        userDoc(request.auth.uid).data.classId == classId;
    }

    function doesNotChangeSensitiveUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'email',
        'teacherId',
        'classId',
        'classCodeUsed',
        'approved',
        'isAdmin',
        'defaultClassId',
        'defaultClassCode',
        'simplePassword',
        'pinHash',
        'pinSalt',
        'pinHashVersion',
        'uid'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isTeacher();
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role == 'student') ||
        (
          request.auth.uid == userId &&
          request.resource.data.uid == userId &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.role == 'teacher' &&
          request.resource.data.approved == false &&
          request.resource.data.isAdmin == false &&
          request.resource.data.keys().hasOnly([
            'uid',
            'email',
            'name',
            'displayName',
            'schoolName',
            'role',
            'approved',
            'isAdmin',
            'createdAt',
            'updatedAt'
          ])
        ) ||
        (isTeacher() && request.resource.data.role == 'student' && request.resource.data.teacherId == request.auth.uid) ||
        (isAdmin() && request.resource.data.role == 'teacher')
      );
      allow update: if isMyStudent(resource.data) ||
        (isOwner(userId) && doesNotChangeSensitiveUserFields()) ||
        isAdmin();
      allow delete: if isMyStudent(resource.data) || isAdmin();
    }

    match /classes/{classId} {
      allow read: if true;
      allow create: if (isTeacher() && request.resource.data.teacherId == request.auth.uid) || isAdmin();
      allow update, delete: if isMyClass(resource.data) || isAdmin();
    }

    match /teacher_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /class_app_approvals/{approvalId} {
      allow read: if isMyClass(resource.data) || isMyClassStudent(resource.data.classId);
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isMyClass(resource.data) || isAdmin();
    }

    match /app_approvals/{appId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    match /usage_logs/{logId} {
      allow read: if isMyStudent(resource.data);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId
        && request.resource.data.keys().hasOnly([
          'userId',
          'userName',
          'teacherId',
          'classId',
          'appName',
          'appCategory',
          'clickedAt'
        ]);
      allow update: if false;
      allow delete: if isMyStudent(resource.data);
    }

    match /user_agreements/{userId} {
      allow read: if isOwner(userId) || isMyStudent(resource.data);
      allow write: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId;
    }

    match /emotional_checkins/{checkinId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.teacherId == userDoc(request.auth.uid).data.teacherId
        && request.resource.data.classId == userDoc(request.auth.uid).data.classId;
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isMyStudent(resource.data));
      allow update: if false;
      allow delete: if isMyStudent(resource.data);
    }
  }
}
